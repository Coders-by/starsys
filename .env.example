# 方舟平台（Ark）OpenAI 兼容接口 —— 小九在线模式用。
# 在 https://console.volcengine.com/ark 开通后拿到 API Key。
ARK_API_KEY="ark-xxxxxxxx"
ARK_BASE_URL="https://ark.cn-beijing.volces.com/api/v3"
ARK_MODEL="glm-4-5-air-20250728"

# APP_URL: The URL where this applet is hosted.
APP_URL="MY_APP_URL"

# 说明：
# - 不配 ARK_API_KEY 也能跑 —— 小九会落到离线兜底（src/lib/xiaojiu.ts 的 pickFallback）。
# - 旧变量名 GEMINI_API_KEY 仍被读取作为 ARK_API_KEY 的回退，兼容旧 .env。
